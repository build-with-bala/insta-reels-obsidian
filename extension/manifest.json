{
  "manifest_version": 3,
  "name": "Insta Reels to Obsidian",
  "version": "1.0.0",
  "description": "Captures Instagram reels from DMs and saves them to Obsidian",
  "permissions": ["storage", "activeTab", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost:7890/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
