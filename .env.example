# LLM API key for auto-tagging (OpenAI or Anthropic key, depending on the
# llm_provider configured in config.yaml).
#
# The server reads this environment variable at startup and it takes
# precedence over llm_api_key in config.yaml — keep real keys here, not in
# config files.
#
# Note: the server does NOT load .env files automatically. Export the
# variable in the shell that starts the server, e.g.:
#
#   cp .env.example .env   # then edit .env
#   set -a; source .env; set +a
#   python -m server.main

INSTA_REELS_LLM_API_KEY=sk-your-key-here
